{
  "name": "@stbr/solana-glossary-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc && cp -r src/i18n/locales dist/i18n/",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "grammy": "^1.34.0",
    "@grammyjs/i18n": "^1.0.2",
    "@grammyjs/auto-retry": "^2.0.1",
    "@grammyjs/ratelimiter": "^1.2.1",
    "@stbr/solana-glossary": "file:../../",
    "better-sqlite3": "^12.0.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
