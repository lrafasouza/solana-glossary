# Required: get from @BotFather on Telegram
BOT_TOKEN=123456789:ABCdefGhijklMNOpqrsTUVwxyz

# Required for webhook mode (Railway sets this automatically)
# Leave empty for local development (uses long polling)
WEBHOOK_DOMAIN=https://your-app.up.railway.app

# Railway sets this automatically; defaults to 3000 locally
PORT=3000
